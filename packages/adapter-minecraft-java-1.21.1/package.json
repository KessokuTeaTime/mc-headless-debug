{
  "name": "@mc-headless-debug/adapter-minecraft-java-1.21.1",
  "version": "0.1.0",
  "type": "module",
  "exports": {
    "./fabric": {
      "types": "./dist/fabric.d.ts",
      "import": "./dist/fabric.js",
      "default": "./dist/fabric.js"
    },
    "./neoforge": {
      "types": "./dist/neoforge.d.ts",
      "import": "./dist/neoforge.js",
      "default": "./dist/neoforge.js"
    }
  },
  "files": [
    "dist",
    "bridge"
  ],
  "scripts": {
